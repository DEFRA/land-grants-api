    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
  
  <changeSet id="grant-create-on-schema-public-v2" author="system">
    <sql>GRANT CREATE ON SCHEMA public TO land_grants_api;</sql>
  </changeSet>

  <changeSet id="grant-truncate-for-land-parcels" author="system">
    <sql>GRANT truncate on land_parcels to land_grants_api;</sql>
  </changeSet>

  <changeSet id="grant-truncate-for-land-covers" author="system">
    <sql>GRANT truncate on land_covers to land_grants_api;</sql>
  </changeSet>

</databaseChangeLog>
